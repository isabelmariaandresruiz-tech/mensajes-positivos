generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum MessageStatus {
  SCHEDULED
  SENT
  CANCELED
  READ
}

enum DeliveryChannel {
  IN_APP
  WHATSAPP
}

enum DeliveryStatus {
  QUEUED
  SENT
  DELIVERED
  FAILED
}

model User {
  id                    String        @id @default(cuid())
  email                 String        @unique
  username              String?       @unique
  phone                 String?
  name                  String
  passwordHash          String
  timezone              String        @default("Europe/Madrid")
  country               String?
  city                  String?
  allowIncomingMessages Boolean       @default(true)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  sentMessages          Message[]     @relation("SentMessages")
  receivedMessages      Message[]     @relation("ReceivedMessages")
  templates             Template[]    @relation("TemplateAuthor")
  invitesCreated        InviteLink[]  @relation("InviteCreator")
  blockedByMe           BlockedUser[] @relation("BlockedByUser")
  blockedMe             BlockedUser[] @relation("BlockedTargetUser")
  reportsFiled          AbuseReport[] @relation("ReportsFiled")
  reportsAgainstMe      AbuseReport[] @relation("ReportsAgainst")
  contacts              Contact[]     @relation("OwnerContacts")
  linkedContacts        Contact[]     @relation("LinkedUserContacts")

  @@index([country])
  @@index([country, city])
}

model Template {
  id        String    @id @default(cuid())
  slug      String    @unique
  title     String
  body      String
  category  String
  isActive  Boolean   @default(true)
  authorId  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  author    User?     @relation("TemplateAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  messages  Message[]

  @@index([category, isActive])
}

model Message {
  id           String            @id @default(cuid())
  senderId     String
  recipientId  String
  templateId   String?
  inReplyToId  String?
  body         String
  scheduledFor DateTime?
  sentAt       DateTime?
  status       MessageStatus     @default(SENT)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  sender       User              @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  recipient    User              @relation("ReceivedMessages", fields: [recipientId], references: [id], onDelete: Cascade)
  template     Template?         @relation(fields: [templateId], references: [id], onDelete: SetNull)
  inReplyTo    Message?          @relation("MessageReplies", fields: [inReplyToId], references: [id], onDelete: SetNull)
  replies      Message[]         @relation("MessageReplies")
  deliveries   MessageDelivery[]
  reports      AbuseReport[]
  invites      InviteLink[]

  @@index([recipientId, status, createdAt])
  @@index([senderId, createdAt])
  @@index([inReplyToId])
}

model InviteLink {
  id          String   @id @default(cuid())
  token       String   @unique
  messageId   String
  createdById String
  expiresAt   DateTime?
  acceptedAt  DateTime?
  createdAt   DateTime @default(now())

  message     Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  createdBy   User     @relation("InviteCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([token])
}

model MessageDelivery {
  id                String          @id @default(cuid())
  messageId         String
  channel           DeliveryChannel @default(IN_APP)
  status            DeliveryStatus  @default(QUEUED)
  providerMessageId String?
  errorCode         String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  message           Message         @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId, channel])
}

model BlockedUser {
  id            String   @id @default(cuid())
  ownerId       String
  blockedUserId String
  createdAt     DateTime @default(now())

  owner         User     @relation("BlockedByUser", fields: [ownerId], references: [id], onDelete: Cascade)
  blockedUser   User     @relation("BlockedTargetUser", fields: [blockedUserId], references: [id], onDelete: Cascade)

  @@unique([ownerId, blockedUserId])
}

model AbuseReport {
  id             String   @id @default(cuid())
  messageId      String
  reporterId     String
  reportedUserId String
  reason         String
  status         String   @default("open")
  createdAt      DateTime @default(now())

  message        Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  reporter       User     @relation("ReportsFiled", fields: [reporterId], references: [id], onDelete: Cascade)
  reportedUser   User     @relation("ReportsAgainst", fields: [reportedUserId], references: [id], onDelete: Cascade)

  @@index([reportedUserId, createdAt])
}

model Contact {
  id           String   @id @default(cuid())
  ownerId      String
  name         String
  phone        String?
  email        String?
  fingerprint  String
  linkedUserId String?
  source       String   @default("phone")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  owner        User     @relation("OwnerContacts", fields: [ownerId], references: [id], onDelete: Cascade)
  linkedUser   User?    @relation("LinkedUserContacts", fields: [linkedUserId], references: [id], onDelete: SetNull)

  @@unique([ownerId, fingerprint])
  @@index([ownerId, createdAt])
}